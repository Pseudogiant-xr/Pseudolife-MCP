# Machine-local compose settings — copy to ops/.env and uncomment what you
# need. ops/.env is gitignored; ops/update.ps1|.sh and the documented compose
# commands pass it via --env-file. Every value here is optional: a missing
# ops/.env runs the stack entirely on defaults.

# ── Volumes ───────────────────────────────────────────────────────────────
# Fresh installs create the defaults once (see docker-compose.yml header):
#   docker volume create pseudolife-mcp-bank
#   docker volume create pseudolife-mcp-state
# Installs that predate the volume rename keep their old names instead:
#PSEUDOLIFE_BANK_VOLUME=ops_pseudolife_pgdata
#PSEUDOLIFE_STATE_VOLUME=ops_pseudolife_data

# ── Postgres ──────────────────────────────────────────────────────────────
# Loopback-only; set BEFORE the first `up` (the image only applies it when
# initializing a fresh volume — changing it later needs ALTER USER, see the
# docker-compose.yml header).
#POSTGRES_PASSWORD=change-me

# ── Daemon ────────────────────────────────────────────────────────────────
# Timezone for episode titles / timestamps (IANA name).
#TZ=Europe/London
# Per-client default toolset tier, e.g. "claude-desktop:minimal,claude-code:core".
# Empty = everyone gets the PSEUDOLIFE_MCP_TOOLSET default.
#PSEUDOLIFE_MCP_TIER_MAP=

# ── Dream extractor ───────────────────────────────────────────────────────
# Default: the in-stack CPU sidecar (http://pseudolife-extractor:8081/v1).
# Point at a bigger model server on the host instead (LM Studio / Ollama /
# llama.cpp / vLLM) — from inside the container the host machine is
# `host.docker.internal`, not `localhost` (resolves on Linux via the
# extra_hosts entry shipped in docker-compose.yml). See README "Upgrading
# the extractor".
#PSEUDOLIFE_DREAM_BASE_URL=http://host.docker.internal:1234/v1
#PSEUDOLIFE_DREAM_MODEL=my-model
#PSEUDOLIFE_DREAM_API_KEY=
#PSEUDOLIFE_DREAM_TIMEOUT_SECONDS=480
#PSEUDOLIFE_DREAM_MAX_TOKENS=2048
# Primary/fallback pair: point BASE_URL above at a primary that may be down
# (e.g. a host-side shim) and FALLBACK at the always-on sidecar; mode `auto`
# probes the primary per dream and falls back. FALLBACK unset = no probe.
#PSEUDOLIFE_DREAM_FALLBACK_BASE_URL=http://pseudolife-extractor:8081/v1
#PSEUDOLIFE_DREAM_FALLBACK_MODEL=extractor
#PSEUDOLIFE_DREAM_EXTRACTOR_MODE=auto
