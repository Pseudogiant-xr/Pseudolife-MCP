# Optional CPU llama.cpp server exposing an OpenAI-compatible API for the dream
# extractor. The default GGUF is BAKED IN (via a throwaway download stage) so
# the stack is batteries-included: `docker compose --profile extractor up`
# needs no manual model step and works offline after the build.
#
# Default rung = Gemma 4 E4B QAT (UD-Q4_K_XL, ~4.2GB). The 2026-07-06 LongMemEval
# knowledge-update bench showed E4B builds a far stronger fact spine than E2B
# (cortex 0.333 vs 0.192, hybrid 0.564 vs 0.474) at only ~1.4x E2B's CPU wall
# time per dream cycle (production-identical serving). Bake the lighter E2B QAT
# (~2.44GB) instead on constrained machines with:
#   --build-arg MODEL_URL=https://huggingface.co/unsloth/gemma-4-E2B-it-qat-GGUF/resolve/main/gemma-4-E2B-it-qat-UD-Q4_K_XL.gguf
# Or, for the benchmark, leave the baked default and mount a different GGUF over
# /models/extractor.gguf at run time (see ops/docker-compose.yml).

ARG MODEL_URL=https://huggingface.co/unsloth/gemma-4-E4B-it-qat-GGUF/resolve/main/gemma-4-E4B-it-qat-UD-Q4_K_XL.gguf

# Stage 1 — fetch the GGUF with a curl-equipped image (the llama.cpp server
# image is minimal and may lack curl/wget).
FROM curlimages/curl:latest AS fetch
ARG MODEL_URL
RUN curl -fSL --retry 3 --retry-delay 5 "$MODEL_URL" -o /tmp/extractor.gguf

# Stage 2 — the OpenAI-compatible CPU server with the model baked in.
FROM ghcr.io/ggml-org/llama.cpp:server
COPY --from=fetch /tmp/extractor.gguf /models/extractor.gguf
EXPOSE 8081
# llama-server is the image ENTRYPOINT; these are its args. --jinja enables the
# chat template so response_format / JSON-object output works; the bind is
# 0.0.0.0 because the compose network (not the host) is the boundary — this
# service is never published to the host. --parallel 1 is explicit because newer
# llama.cpp images default to 4 slots sharing ONE unified KV buffer — concurrent
# ~4k-token dream calls then exceed the context and every request 500s
# ("Context size has been exceeded"); one slot serializes = old behaviour.
CMD ["--model", "/models/extractor.gguf", \
     "--host", "0.0.0.0", "--port", "8081", \
     "--ctx-size", "8192", "--jinja", "--parallel", "1"]
