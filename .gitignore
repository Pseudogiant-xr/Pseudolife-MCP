# Local compose env overrides (machine-specific volume names etc.) — never committed.
.env

# Machine-local compose overrides (e.g. fine-tuned GGUF mounts over the baked
# extractor default) — referencing personal files from the tracked compose file
# would break fresh clones, so they live here instead.
ops/docker-compose.override.yml

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.venv/
venv/
build/
dist/

# Memory state — never committed; this is *Claude's* memory, per-machine.
data/
memory_state/
*.pt

# ChromaDB
chromadb/

# Benchmark datasets (LongMemEval etc.) — downloaded, never committed
evals/data/

# Overnight-runner console logs (results JSONLs are committed, raw logs not)
evals/results/*.log

# Per-question fact-bank dumps (diagnostic, regenerable, ~MBs)
evals/results/banks/

# Cortex Console dev-server scratch (fixture config writes)
pseudolife_memory/web/.devdata/
*.bak

# Tee'd deploy-script output from working sessions — regenerable scratch.
deploy-*.log

# UI QA scratch (screenshots, browser-driver output)
.qa/
.playwright-mcp/
pseudolife_memory/web/.devserver.log

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
unsloth_compiled_cache/

# regression-gate transient working files (stage-0 cleans them each run)
evals/results/*-gate.jsonl
evals/results/*-gate-r*.jsonl
evals/results/*-gate.agg.json
evals/results/*-gate*.summary.json
